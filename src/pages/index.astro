---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			body {
				margin: 0;
				padding: 0;
				background: #010058;
				min-height: 100vh;
			}
			.hero {
				background: #010058;
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				color: white;
				padding: 2rem;
			}
			.logo-container {
				margin-bottom: 2rem;
			}
			.logo-placeholder {
				width: 200px;
				height: 200px;
				margin: 0 auto 1rem;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.logo-placeholder img {
				width: 100%;
				height: 100%;
				object-fit: contain;
			}
			.app-title {
				font-size: 4rem;
				font-weight: bold;
				margin-bottom: 1rem;
				text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
				color: white;
			}
			.app-description {
				font-size: 1.5rem;
				max-width: 600px;
				margin: 0 auto 2rem;
				line-height: 1.6;
				opacity: 0.9;
			}
			.download-section {
				margin-top: 3rem;
			}
			.app-store-button {
				display: inline-block;
				background: #000;
				color: white;
				padding: 1rem 2rem;
				border-radius: 10px;
				text-decoration: none;
				font-weight: bold;
				transition: transform 0.3s ease, box-shadow 0.3s ease;
				margin: 0 1rem;
			}
			.app-store-button:hover {
				transform: translateY(-2px);
				box-shadow: 0 10px 25px rgba(0,0,0,0.3);
			}
			.features {
				padding: 4rem 2rem;
				background: #010058;
			}
			.features-container {
				max-width: 1200px;
				margin: 0 auto;
				text-align: center;
			}
			.features h2 {
				font-size: 2.5rem;
				margin-bottom: 3rem;
				color: white;
			}
			.feature-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 2rem;
				margin-top: 2rem;
			}
			.feature-card {
				background: white;
				padding: 2rem;
				border-radius: 10px;
				box-shadow: 0 5px 15px rgba(0,0,0,0.1);
			}
			.feature-icon {
				font-size: 3rem;
				margin-bottom: 1rem;
			}
			.feature-title {
				font-size: 1.5rem;
				margin-bottom: 1rem;
				color: #12124a;
			}
			.feature-description {
				color: #666;
				line-height: 1.6;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div>
					<div class="logo-container">
						<div class="logo-placeholder">
							<img src="/ashworks-icon.png" alt="AshWorks Logo" />
						</div>
					</div>
					<h1 class="app-title">AshWorks</h1>
					<p class="app-description">
						AshWorks is the essential mobile app for therapists, designed to streamline your practice and make your day easier. 
						Organize client notes, manage appointments, and access critical information securely - all from your mobile device.
					</p>
					<div class="download-section">
						<a href="/download" class="app-store-button">
							📱 Download AshWorks
						</a>
					</div>
				</div>
			</section>

			<section class="features">
				<div class="features-container">
					<h2>Why Choose AshWorks?</h2>
					<div class="feature-grid">
						<div class="feature-card">
							<div class="feature-icon">📊</div>
							<h3 class="feature-title">Productivity Tracking</h3>
							<p class="feature-description">
								Clearly track your daily productivity with intuitive dashboards and analytics that help you optimize your therapy practice workflow.
							</p>
						</div>
						<div class="feature-card">
							<div class="feature-icon">�</div>
							<h3 class="feature-title">Clinical Skills Library</h3>
							<p class="feature-description">
								Quickly access information on often used clinical skills and techniques with our comprehensive, searchable reference library.
							</p>
						</div>
						<div class="feature-card">
							<div class="feature-icon">🏋️</div>
							<h3 class="feature-title">Exercise Plans</h3>
							<p class="feature-description">
								Create personalized exercise plans and easily send them directly to patients for better engagement and treatment outcomes.
							</p>
						</div>
					</div>
				</div>
			</section>

			<section class="hero" style="background: #010058;">
				<div>
					<h2 style="font-size: 2.5rem; margin-bottom: 1rem; color: white;">Ready to Get Started?</h2>
					<p style="font-size: 1.2rem; margin-bottom: 2rem; color: white;">
						Join thousands of users who have already discovered the AshWorks difference.
					</p>
					<a href="/download" class="app-store-button">
						📱 Download Now
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
